# LLM provider configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Provider choices: ollama (default)
LLM_PROVIDER=groq
#LLM_PROVIDER=ollama

# For ollama provider, set the local model name.
# Example free local model: llama3.1:8b
LLM_MODEL=llama3.1:8b

# Optional: FastAPI port
PORT=8000

# MCP integration (optional)
MCP_ENABLED=false

# JSON array of MCP server definitions.
# Example for an MCP filesystem server via npx:
# MCP_SERVERS_JSON=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]
MCP_SERVERS_JSON=[]
